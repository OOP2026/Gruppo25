<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.CaricaTesi">
  <scrollpane id="2ae2f">
    <constraints>
      <xy x="20" y="20" width="687" height="460"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="27dc6" binding="panelCaricaTesi" layout-manager="GridLayoutManager" row-count="7" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="65ad6" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="14"/>
              <text value="Carica qui la tua Tesi"/>
            </properties>
          </component>
          <component id="99e1" class="javax.swing.JLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Titolo:"/>
            </properties>
          </component>
          <component id="f5657" class="javax.swing.JTextField" binding="titoloTesiTextField">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="0" fill="0" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="11aa4" class="javax.swing.JLabel">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Contenuto:"/>
            </properties>
          </component>
          <scrollpane id="3ccae">
            <constraints>
              <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="765ed" class="javax.swing.JTextArea" binding="tesiTextArea">
                <constraints/>
                <properties>
                  <inheritsPopupMenu value="false"/>
                  <lineWrap value="true"/>
                  <opaque value="true"/>
                  <wrapStyleWord value="true"/>
                </properties>
              </component>
            </children>
          </scrollpane>
          <component id="c6e5f" class="javax.swing.JButton" binding="okbutton" default-binding="true">
            <constraints>
              <grid row="6" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="OK"/>
            </properties>
          </component>
          <component id="98aa7" class="javax.swing.JButton" binding="annullaButton" default-binding="true">
            <constraints>
              <grid row="6" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Annulla"/>
            </properties>
          </component>
          <hspacer id="fed86">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
          </hspacer>
          <component id="26dfd" class="javax.swing.JComboBox" binding="comboBoxDateSeduteDiLaurea">
            <constraints>
              <grid row="4" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <model>
                <item value="--- Seleziona una data ---"/>
                <item value="&quot;Seduta Estiva - 17 Giugno 2026&quot;"/>
                <item value="&quot;Seduta Estiva - 24 Giugno 2026&quot;"/>
                <item value="&quot;Seduta Estiva - 1 Luglio 2026&quot;"/>
