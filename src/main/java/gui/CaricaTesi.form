                <item value="&quot;Seduta Estiva - 22 Luglio 2026&quot;"/>
                <item value="&quot;Seduta Autunnale - 15 Ottobre 2026&quot;"/>
                <item value="&quot;Seduta Autunnale - 22 Ottobre 2026&quot;"/>
                <item value="&quot;Seduta Autunnale - 29 Ottobre 2026&quot;"/>
