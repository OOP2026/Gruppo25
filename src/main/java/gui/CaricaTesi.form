                <item value="&quot;Seduta Autunnale - 19 Novembre 2026&quot;"/>
                <item value="&quot;Seduta Autunnale - 26 Novembre 2026&quot;"/>
                <item value="&quot;Seduta Autunnale - 21 Dicembre 2026&quot;"/>
